#!/bin/bash
# Pre-commit hook: keep broken code out of history.
#
#  1. Web build — when any staged file touches web/, run `npm run build` (vite) so a
#     broken frontend build can never be committed. Output is gitignored (web/dist,
#     web/.svelte-kit) so it never dirties the tree.
#  2. Python lint — when any staged .py file changes, run ruff's pyflakes subset
#     (`--select F`) on the staged files. F catches undefined names (F821), unused
#     imports/vars (F401/F841), redefinitions (F811) — i.e. the NameError-on-rename
#     class. Per-staged-file is enough (F rules are intra-file).
#
# Either failure aborts the commit. Both stay instant when nothing relevant is staged
# (doc-only commits skip both).
#
# Bypass for a one-off WIP commit:  git commit --no-verify
# Enabled via:  git config core.hooksPath .githooks  (see .githooks/README.md)
#
# NB: #!/bin/bash (not /usr/bin/env bash) — env is uutils-rs on this box and the
# env-shebang path is broken (Ubuntu 26.04).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

# ── 1) Web build (only if a web/ file is staged) ─────────────────────────────
if printf '%s\n' "$staged" | grep -q '^web/'; then
	log="$(mktemp -t tinkerscope-precommit-build.XXXXXX.log)"
	echo "pre-commit: staged web/ changes detected — running 'npm run build'…"
	if ( cd "$repo_root/web" && npm run build ) >"$log" 2>&1; then
		echo "✓ pre-commit: web build OK"
		rm -f "$log"
	else
		echo "" >&2
		echo "✗ pre-commit: web build FAILED — commit aborted." >&2
		echo "  Last 40 lines of the build output ($log):" >&2
		echo "  ----------------------------------------------------------------" >&2
		tail -n 40 "$log" | sed 's/^/  /' >&2
		echo "  ----------------------------------------------------------------" >&2
		echo "  Fix the build, or bypass with: git commit --no-verify" >&2
		exit 1
	fi
fi

# ── 2) Python lint (only the staged .py files) ───────────────────────────────
py_files="$(printf '%s\n' "$staged" | grep '\.py$' || true)"
if [ -n "$py_files" ]; then
	ruff="$repo_root/.venv/bin/ruff"
	[ -x "$ruff" ] || ruff="ruff"   # fall back to PATH if the venv symlink is gone
	echo "pre-commit: linting staged Python (ruff --select F)…"
	# shellcheck disable=SC2086  # word-split the newline list into per-file args
	if printf '%s\n' "$py_files" | xargs "$ruff" check --select F; then
		echo "✓ pre-commit: ruff F OK"
	else
		echo "" >&2
		echo "✗ pre-commit: ruff found errors — commit aborted." >&2
		echo "  Fix them, or bypass with: git commit --no-verify" >&2
		exit 1
	fi
fi

exit 0
